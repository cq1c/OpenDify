# ═══════════════════════════════════════
#  OpenDify Lite 配置
# ═══════════════════════════════════════

# ── 日志 ──
LOG_LEVEL=WARNING                  # DEBUG | INFO | WARNING | ERROR

# ── 服务器 ──
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# ── 认证 ──
VALID_API_KEYS=sk-your-secret-key
AUTH_MODE=required                 # required | disabled

# ── Dify 配置 ──
DIFY_API_BASE=https://api.dify.ai/v1
DIFY_API_KEY=app-xxxxxxxxxxxxxxxx
DIFY_MODEL_NAME=my-weak-model

# 多模型映射（可选）
# DIFY_MODEL_MAP=聊天助手测试:app-xxx,代码助手:app-yyy

# ── 超时 ──
TIMEOUT=120

# ── 会话模式 ──
CONVERSATION_MODE=auto             # none | auto

# ── 弱模型优化 ──
# 首次之后是否省略系统提示词（利用 Dify 会话记忆）
STRIP_SYSTEM_AFTER_FIRST=false

# 系统提示词最大长度（0=不截断）
SYSTEM_PROMPT_MAX_LENGTH=0

# 使用简化的工具定义格式（推荐弱模型开启）
SIMPLIFIED_TOOL_DEFS=true

# 工具描述最大长度
TOOL_DESC_MAX_LENGTH=120

# 仅发送最近 N 条消息（0=全部）
ONLY_RECENT_MESSAGES=0

# ── 工具调用强度分级（0~6） ──
# 0 = off       极简提示，不加任何警告。适用于强模型（Claude / GPT-4）
# 1 = polite    当前老默认，结尾有硬约束（中等模型）
# 2 = assertive 强命令式 + "⚠️ 强制规则" + 前夹击 + role=tool 追加提醒（弱模型默认）
# 3 = aggressive + 后果警告 "输出将被丢弃" + 正则兜底（非常弱的模型）
# 4 = nuclear   + 规则重复 + "最后一次机会" + 加粗前后夹击（救命稻草）
# 5 = savage    脏话发泄模式，日志自动脱敏（本地调试，云 Dify 可能被过滤拒绝）
# 6 = classical 文言文正常语气（劝谏体，非辱骂），实验档位
TOOL_CALL_STRICTNESS=2

# 以下两项为 strictness 的细粒度 override, 显式设置时覆盖分级默认。
# 未设置时由 TOOL_CALL_STRICTNESS 决定：>=1 开启 USE_TOOL_TOKEN，>=3 开启 AGGRESSIVE_TOOL_RECOVERY
# USE_TOOL_TOKEN=true              # 使用 <tool-calls token="xxxx">...</tool-calls>（防提示词串扰）
# AGGRESSIVE_TOOL_RECOVERY=false   # 所有标签兜底失败时，正则扫描 tool_name({...}) 样式抢救

# Level 5 日志脱敏（默认 true，关掉则日志文件里会留下原始脏话文本）
SAVAGE_LOG_REDACT=true

# ── 工具描述摘要缓存（实验功能，默认关闭） ──
# 开启后：首次见到某个工具时用原描述，后台异步调 Dify 生成极简摘要写入磁盘；
# 下次命中 → 直接用摘要替换描述，缩短上下文。参数 schema 永不压缩。
TOOL_DESC_DIGEST_ENABLED=false
TOOL_DESC_DIGEST_DIR=.cache/prompt_digest
TOOL_DESC_DIGEST_MAX_CHARS=40

# ── 连接池 ──
POOL_SIZE=50

# ═══════════════════════════════════════
#  请求/响应流量日志
# ═══════════════════════════════════════
# 开启后将客户端⇄代理⇄Dify 的完整数据写入独立日志文件，方便调试

REQUEST_LOG_ENABLED=false          # true | false
REQUEST_LOG_DIR=logs               # 日志文件目录
REQUEST_LOG_MAX_SIZE=52428800      # 单个日志文件最大字节数（默认 50MB）
REQUEST_LOG_BACKUP_COUNT=5         # 保留的历史日志文件数量
REQUEST_LOG_MAX_BODY=0             # 单条记录的 body 最大字符数（0=不截断）