# OpenDify 配置示例
# 复制为 .env 并按需修改

# === 日志 ===
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=WARNING

# === OpenAI 兼容层鉴权 ===
# required: 必须携带 Authorization: Bearer <key>
# disabled: 不校验（仅建议本地/内网）
AUTH_MODE=required

# 代理服务的 API keys（逗号分隔）
VALID_API_KEYS=sk-abc123,sk-def456

# === Dify 后端 ===
# Dify API Base（默认 https://api.dify.ai/v1）
DIFY_API_BASE=https://api.dify.ai/v1

# Dify 应用 API keys（逗号分隔）
DIFY_API_KEYS=app-xxxxxxxxxxxxxxxx,app-yyyyyyyyyyyyyyyy

# TLS 校验（自签证书可设为 false）
DIFY_SSL_VERIFY=true

# === 对话历史/性能 ===
# 1: 每次把完整 messages 转成 query（最兼容 OpenAI 无状态）
# 2: 当提供 conversation_id 时，仅发送“最新增量”消息（长对话更快）
CONVERSATION_MEMORY_MODE=1

# === 服务监听与超时 ===
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
WORKERS=1
TIMEOUT=30.0


# === 2anthropic（Claude Code / Anthropic SDK -> OpenAI Chat Completions 上游）===
# 上游 OpenAI Chat Completions 地址：
# - 可填完整 endpoint：https://example.com/v1/chat/completions
# - 或填 base：https://example.com 或 https://example.com/v1（会自动补全到 /v1/chat/completions）
UPSTREAM_OPENAI_BASE_URL=https://example.com/v1/chat/completions
# 上游鉴权（Authorization: Bearer <key>）
UPSTREAM_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# 上游默认模型（不填则使用请求里的 model）
UPSTREAM_OPENAI_MODEL=claude-opus-4-5
# 或按“请求里的 model”映射到上游 model（优先级高于 UPSTREAM_OPENAI_MODEL）：
# UPSTREAM_OPENAI_MODEL_MAP=claude-3-5-sonnet-20241022:claude-opus-4-5,claude-3-opus-20240229:claude-opus-4-5
# 未传 max_tokens 时默认值
UPSTREAM_OPENAI_MAX_TOKENS=1024
# TLS 校验（自签证书可设为 false）
UPSTREAM_OPENAI_SSL_VERIFY=true

# === Claude Code / Anthropic SDK 兼容（Dify 后端）===
# Claude Code 发送的 model 往往是 Anthropic 模型名，可映射到 Dify 应用名：
# CLAUDE_MODEL_MAP=claude-3-5-sonnet-20241022:Your-Dify-App-Name,claude-3-opus-20240229:Another-Dify-App
#
# 或者直接指定默认使用哪个 Dify 应用（当传入的 model 不存在/未映射时会 fallback 到它；若不配置则 fallback 到第一个模型）：
# CLAUDE_DEFAULT_MODEL=Your-Dify-App-Name
